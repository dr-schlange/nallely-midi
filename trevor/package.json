{
	"name": "trevor",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"build:analyze": "tsc -b && vite build --mode analyze",
		"format": "yarn format-trevor && yarn format-jslib",
		"format-trevor": "biome format src --fix",
		"format-jslib": "biome format src --fix ../libs/js",
		"preview": "vite preview",
		"deploy:gh": "GH=true yarn build && gh-pages -d dist"
	},
	"dependencies": {
		"@codemirror/autocomplete": "^6.20.1",
		"@codemirror/lang-python": "^6.2.1",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/modifiers": "^9.0.0",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@reduxjs/toolkit": "^2.11.2",
		"@replit/codemirror-vim": "^6.3.0",
		"@uiw/react-codemirror": "^4.25.9",
		"ansi_up": "^6.0.6",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-redux": "^9.2.0",
		"uplot": "^1.6.32",
		"uplot-react": "^1.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"gh-pages": "^6.3.0",
		"globals": "^17.5.0",
		"rollup-plugin-visualizer": "^7.0.1",
		"typescript": "~6.0.2",
		"vite": "^8.0.8",
		"vite-plugin-compression2": "^2.5.3"
	}
}
